# =============================================================================
# PASTEC Backend - Configuration des variables d'environnement (EXEMPLE)
# =============================================================================
# Ce fichier sert de template. Créez vos propres fichiers .env.dev ou .env.prod
# et renseignez les valeurs sensibles. NE COMMITEZ JAMAIS les fichiers .env
# contenant des secrets réels.
# =============================================================================

# -----------------------------------------------------------------------------
# Configuration de l'application FastAPI
# -----------------------------------------------------------------------------
APP_MODULE=main:app
WEB_CONCURRENCY=4
GUNICORN_TIMEOUT=120

# -----------------------------------------------------------------------------
# Configuration Keycloak
# -----------------------------------------------------------------------------
# URL publique de Keycloak (accessible depuis l'extérieur)
KEYCLOAK_SERVER_URL=https://your-keycloak-domain.com/auth

# URL interne de Keycloak (pour communication entre conteneurs)
KEYCLOAK_INTERNAL_SERVER_URL=http://keycloak:8080

# Realm Keycloak
KEYCLOAK_REALM=pastec

# Client ID pour l'application
KEYCLOAK_CLIENT_ID=pastec_server

# Secret du client (SENSIBLE - à générer depuis Keycloak)
KEYCLOAK_CLIENT_SECRET=CHANGEME_CLIENT_SECRET

# Secret du client admin (SENSIBLE - à générer depuis Keycloak)
KEYCLOAK_ADMIN_CLIENT_SECRET=CHANGEME_ADMIN_CLIENT_SECRET

# Credentials admin Keycloak principal
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=CHANGEME_KEYCLOAK_ADMIN_PASSWORD

# Credentials admin PASTEC (utilisateur applicatif)
KEYCLOAK_PASTEC_ADMIN=pastec-admin
KEYCLOAK_PASTEC_ADMIN_PASSWORD=CHANGEME_PASTEC_ADMIN_PASSWORD

# Credentials de test (uniquement pour dev)
TEST_ADMIN_USERNAME=test_admin
TEST_ADMIN_PASSWORD=CHANGEME_TEST_PASSWORD

# -----------------------------------------------------------------------------
# Configuration MongoDB
# -----------------------------------------------------------------------------
MONGODB_URI=mongodb://mongodb:27017/pastec_db
MONGODB_DB_NAME=pastec_db

# -----------------------------------------------------------------------------
# Configuration PostgreSQL (pour Keycloak)
# -----------------------------------------------------------------------------
POSTGRES_DB=keycloak
POSTGRES_USER=keycloak
POSTGRES_PASSWORD=CHANGEME_POSTGRES_PASSWORD

# -----------------------------------------------------------------------------
# Configuration AI Worker
# -----------------------------------------------------------------------------
AI_WORKER_URL=http://ai_worker:8001
FASTAPI_URL=http://fastapi-app:8000

# -----------------------------------------------------------------------------
# Sécurité
# -----------------------------------------------------------------------------
# Pepper pour le hachage (SENSIBLE - générez une clé aléatoire forte)
JWT_PEPPER=CHANGEME_RANDOM_PEPPER_KEY
